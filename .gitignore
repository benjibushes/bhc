.agents/
.claude/worktrees/
.claude/skills/agent-browser
.claude/skills/find-skills
.claude/skills/mcp-builder
.claude/skills/stripe-best-practices
.claude/skills/stripe-projects
.claude/skills/upgrade-stripe
skills-lock.json

