# BuyHalfCow Environment Variables
# Copy this file to .env.local and fill in your actual values

# ==============================================
# AIRTABLE (Database)
# ==============================================
# Get these from: https://airtable.com/account
AIRTABLE_API_KEY=patABC123YourKeyHere
AIRTABLE_BASE_ID=appXYZ789YourBaseId

# ==============================================
# RESEND (Email Service)
# ==============================================
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email addresses
EMAIL_FROM=noreply@buyhalfcow.com
ADMIN_EMAIL=admin@buyhalfcow.com

# Resend Inbound webhook signing secret (Resend dashboard → Inbound endpoint → "Signing Secret")
RESEND_INBOUND_WEBHOOK_SECRET=whsec_xxx

# Where to forward every inbound for full-body review. Optional. Falls back to ADMIN_EMAIL.
ADMIN_EMAIL_FOR_FORWARD=ben@example.com

# ==============================================
# SITE CONFIGURATION
# ==============================================
# Update this with your actual domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For production: https://buyhalfcow.com

# ==============================================
# ADMIN AUTH (Phase 0 — Clerk for browser admins)
# ==============================================
# Browser admin access flows through Clerk (TOTP 2FA + email allowlist).
# Server-to-server callers (Telegram bot, cron jobs, ops scripts) keep
# using ADMIN_PASSWORD via the `x-admin-password` HTTP header.

# Clerk keys — get from https://dashboard.clerk.com → API Keys.
# Phase 0 (admin surface), Phase 1 (buyer surface, gated), and Phase 2
# (rancher surface, gated) all use Clerk.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Auth Phase 1 — Clerk for buyer surface. When 'true', buyers authenticate
# via Clerk + their Airtable Consumers row links to Clerk User Id on first
# login (auto-link by primary email). When 'false' (default), the legacy
# bhc-member-auth JWT cookie continues working as the sole buyer auth path.
# Plan: ship flag=false, flip to true after smoke test, soak 30 days, then
# remove the legacy path in a separate cleanup commit. Rollback = flip
# back to false. See docs/AUTH-CLERK-BUYER.md.
CLERK_BUYER_ENABLED=false

# Auth Phase 2 — Clerk for rancher surface. When 'true', ranchers
# authenticate via Clerk + their Airtable Ranchers row links to Clerk User
# Id on first login. Auto-link matches the Clerk primary email against
# the Ranchers row's primary `Email` field OR any address in the
# multiline `Team Emails` field (operator + spouse + hired help all
# authorized). When 'false' (default), the legacy bhc-rancher-auth JWT
# cookie continues working as the sole rancher auth path. Mirrors the
# Phase 1 buyer flag. Plan: ship flag=false, flip to true after smoke,
# soak 30 days, then remove the legacy path in a separate cleanup
# commit. Rollback = flip back to false. See docs/AUTH-CLERK-RANCHER.md.
CLERK_RANCHER_ENABLED=false

# Comma-separated list of email addresses authorized as admins. Must match
# the Clerk session's primary email after sign-in. If empty, ANY signed-in
# Clerk user can hit /admin (DEV ONLY — always set this in prod).
ADMIN_EMAILS=ben@buyhalfcow.com

# Programmatic admin password — used by Telegram bot, cron jobs, ops curl
# scripts that hit /api/admin/* with the x-admin-password header. NOT used
# for browser admin access (that flows through Clerk). Rotate quarterly.
ADMIN_PASSWORD=your_secure_password_here

# ==============================================
# COMMISSION & REVENUE TRACKING
# ==============================================
# Commission rate as a FRACTION (0.10 = 10%). lib/commission.ts normalizes
# either form (0.10 OR 10), but stick to fractions to keep server + client
# in lock-step. Setting this wrong has bitten us before — 10× billing on a
# bad env flip.
NEXT_PUBLIC_COMMISSION_RATE=0.10

# ==============================================
# AI SKILLS — priority: Ollama → Groq (free) → Anthropic (paid)
# ==============================================
# LOCAL DEV — Ollama (completely free, runs on your machine)
# Make sure Ollama is running: `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# PRODUCTION (FREE) — Groq API, free tier, fast
# Sign up at console.groq.com → API Keys → Create Key
GROQ_API_KEY=gsk_your_groq_key_here

# PRODUCTION (PAID fallback) — Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# ==============================================
# STRIPE (Brand listing payments)
# ==============================================
# Required for brand payment gatekeeping
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Connect webhook signing secret. Separate from STRIPE_WEBHOOK_SECRET —
# Connect events fire on a different Stripe Dashboard endpoint registration.
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
# Optional: override default $299 brand listing fee (in cents)
# BRAND_LISTING_PRICE_CENTS=29900

# ==============================================
# SETUP INSTRUCTIONS
# ==============================================
# 
# 1. Create an Airtable account:
#    - Go to https://airtable.com
#    - Sign up (free)
#    - Create new workspace: "BuyHalfCow"
#    - Create new base: "BHC CRM"
#
# 2. Create tables in Airtable (just click "+ Add Table"):
#    See AIRTABLE_SETUP.md for exact field configuration
#
# 3. Get your API credentials:
#    - Click account icon → Account
#    - Scroll to "API" section
#    - Generate personal access token → Copy as AIRTABLE_API_KEY
#    - Go to your base → Help → API documentation
#    - Find "The ID of this base is appXXXXXXXXXX" → Copy as AIRTABLE_BASE_ID
#
# 4. Create a Resend account:
#    - Go to https://resend.com
#    - Sign up
#    - Verify your domain (buyhalfcow.com)
#    - Get API key from dashboard
#
# 5. Test locally:
#    - Copy this file to .env.local
#    - Fill in all values above
#    - Run: npm run dev
#    - Test forms at http://localhost:3000
#
# 6. Deploy:
#    - Push code to GitHub
#    - Connect to Vercel
#    - Add these same env vars in Vercel dashboard
#    - Update NEXT_PUBLIC_SITE_URL to production URL
#
